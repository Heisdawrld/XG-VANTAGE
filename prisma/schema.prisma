// xG-Vantage — Football Intelligence Platform
// Complete database schema for the prediction engine + SaaS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE FOOTBALL DATA
// ============================================================================

model League {
  id           Int      @id
  name         String
  country      String   @default("")
  isActive     Boolean  @default(true)
  isWomen      Boolean  @default(false)
  currentSeasonId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seasons   Season[]
  standings Standing[]
  fixtures  Fixture[]

  @@index([isActive])
  @@index([country])
}

model Season {
  id         Int      @id
  leagueId   Int
  name       String
  year       Int
  startDate  DateTime?
  endDate    DateTime?
  isCurrent  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  league    League   @relation(fields: [leagueId], references: [id])
  standings Standing[]
  fixtures  Fixture[]

  @@index([leagueId])
  @@index([isCurrent])
}

model Venue {
  id           Int      @id
  name         String
  city         String   @default("")
  country      String   @default("")
  countryCode  String   @default("")
  capacity     Int?
  latitude     Float?
  longitude    Float?
  pitchLengthM Float?
  pitchWidthM  Float?
  homeTeamId   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([countryCode])
  @@index([homeTeamId])
}

model Manager {
  id                   Int      @id
  name                 String
  shortName            String   @default("")
  country              String   @default("")
  tacticalProfile      String   @default("balanced") // attacking, defensive, balanced
  preferredFormation   String   @default("")
  currentTeamId        Int?
  matchesTotal         Int      @default(0)
  wins                 Int      @default(0)
  draws                Int      @default(0)
  losses               Int      @default(0)
  winPct               Float    @default(0)
  avgGoalsScored       Float    @default(0)
  avgGoalsConceded     Float    @default(0)
  avgPossession        Float    @default(50)
  cleanSheetPct        Float    @default(0)
  bttsPct              Float    @default(0)
  over25Pct            Float    @default(0)
  teamStyle            String   @default("") // possession, counter, pressing, defensive, wide
  statsUpdatedAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([currentTeamId])
  @@index([tacticalProfile])
}

model Player {
  id               Int      @id
  name             String
  shortName        String   @default("")
  position         String   @default("") // G, D, M, F
  specificPosition String   @default("") // AM, CB, etc
  jerseyNumber     Int?
  dateOfBirth      String?
  heightCm         Int?
  weightKg         Int?
  preferredFoot    String   @default("")
  nationality      String   @default("")
  currentTeamId    Int?
  nationalTeamId   Int?
  marketValueEur   Int?
  contractUntil    String?
  availability     String   @default("available")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  matchStats   PlayerMatchStat[]
  squadEntries SquadPlayer[]

  @@index([currentTeamId])
  @@index([position])
}

model Team {
  id              Int      @id
  name            String
  shortName       String   @default("")
  country         String   @default("")
  venueId         Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  homeFixtures Fixture[] @relation("HomeTeam")
  awayFixtures Fixture[] @relation("AwayTeam")
  standings    Standing[]
  dna          TeamDNA?
  elo          TeamELO[]
  formHistory  TeamForm[]
  squadPlayers SquadPlayer[]

  @@index([country])
}

model SquadPlayer {
  id         String  @id @default(cuid())
  teamId     Int
  playerId   Int
  role       String  @default("player") // player, captain
  createdAt  DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([teamId, playerId])
}

model Fixture {
  id                Int       @id
  leagueId          Int
  seasonId          Int?
  homeTeamId        Int
  awayTeamId        Int
  homeCoachId       Int?
  awayCoachId       Int?
  refereeId         Int?
  venueId           Int?
  eventDate         DateTime
  status            String    @default("notstarted") // notstarted, inprogress, finished, postponed, cancelled
  roundNumber       Int?
  roundName         String    @default("")
  groupName         String?
  period            String?   // 1st_half, halftime, 2nd_half, extra_time, FT, penalties
  currentMinute     Int?
  homeScore         Int?
  awayScore         Int?
  homeScoreHt       Int?
  awayScoreHt       Int?
  penaltyShootout   String?
  extraTimeScore    String?
  isLocalDerby      Boolean   @default(false)
  isNeutralGround   Boolean   @default(false)
  travelDistanceKm  Int?
  weatherCode       Int?
  weatherDesc       String?
  windSpeed         Float?
  temperatureC      Float?
  pitchCondition    Int?
  attendance        Int?
  liveWebsocket     Boolean   @default(false)
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  league     League   @relation(fields: [leagueId], references: [id])
  season     Season?  @relation(fields: [seasonId], references: [id])
  homeTeam   Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  stats      FixtureStats?
  incidents  FixtureIncident[]
  lineup     FixtureLineup?
  odds       FixtureOdds?
  metadata   FixtureMetadata?
  playerStats PlayerMatchStat[]
  prediction  Prediction?
  outcome     PredictionOutcome?

  @@index([status])
  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([eventDate])
  @@index([leagueId, status])
  @@index([homeTeamId, eventDate])
  @@index([awayTeamId, eventDate])
}

model FixtureStats {
  id                    String   @id @default(cuid())
  fixtureId             Int      @unique

  // Home stats
  homeTotalShots        Int      @default(0)
  homeShotsOnTarget     Int      @default(0)
  homeShotsOffTarget    Int      @default(0)
  homeBlockedShots      Int      @default(0)
  homeShotsInsideBox    Int      @default(0)
  homeShotsOutsideBox   Int      @default(0)
  homeBigChances        Int      @default(0)
  homeBigChancesScored  Int      @default(0)
  homeBigChancesMissed  Int      @default(0)
  homeHitWoodwork       Int      @default(0)
  homeCornerKicks       Int      @default(0)
  homeOffsides          Int      @default(0)
  homeBallPossession    Float    @default(50)
  homePassAccuracy      Float    @default(0)
  homePasses            Int      @default(0)
  homeAccuratePasses    Int      @default(0)
  homeTotalTackles      Int      @default(0)
  homeInterceptions     Int      @default(0)
  homeClearances        Int      @default(0)
  homeDribblesSuccess   Int      @default(0)
  homeDribblesTotal     Int      @default(0)
  homeAerialDuelsWon    Int      @default(0)
  homeAerialDuelsTotal  Int      @default(0)
  homeFouls             Int      @default(0)
  homeYellowCards       Int      @default(0)
  homeRedCards          Int      @default(0)
  homeAttacks           Int      @default(0)
  homeDangerousAttacks  Int      @default(0)
  homeExpectedGoals     Float    @default(0)
  homeGoalsPrevented    Float    @default(0)

  // Away stats
  awayTotalShots        Int      @default(0)
  awayShotsOnTarget     Int      @default(0)
  awayShotsOffTarget    Int      @default(0)
  awayBlockedShots      Int      @default(0)
  awayShotsInsideBox    Int      @default(0)
  awayShotsOutsideBox   Int      @default(0)
  awayBigChances        Int      @default(0)
  awayBigChancesScored  Int      @default(0)
  awayBigChancesMissed  Int      @default(0)
  awayHitWoodwork       Int      @default(0)
  awayCornerKicks       Int      @default(0)
  awayOffsides          Int      @default(0)
  awayBallPossession    Float    @default(50)
  awayPassAccuracy      Float    @default(0)
  awayPasses            Int      @default(0)
  awayAccuratePasses    Int      @default(0)
  awayTotalTackles      Int      @default(0)
  awayInterceptions     Int      @default(0)
  awayClearances        Int      @default(0)
  awayDribblesSuccess   Int      @default(0)
  awayDribblesTotal     Int      @default(0)
  awayAerialDuelsWon    Int      @default(0)
  awayAerialDuelsTotal  Int      @default(0)
  awayFouls             Int      @default(0)
  awayYellowCards       Int      @default(0)
  awayRedCards          Int      @default(0)
  awayAttacks           Int      @default(0)
  awayDangerousAttacks  Int      @default(0)
  awayExpectedGoals     Float    @default(0)
  awayGoalsPrevented    Float    @default(0)

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model FixtureIncident {
  id           String  @id @default(cuid())
  fixtureId    Int
  type         String  // goal, card, substitution, period, injuryTime, varDecision
  minute       Int
  addedTime    Int?
  player       String?
  playerId     Int?
  playerIn     String?
  playerInId   Int?
  playerOut    String?
  playerOutId  Int?
  isHome       Boolean?
  cardType     String? // yellow, red, yellowRed
  goalType     String? // normal, penalty, own
  decision     String? // for VAR
  confirmed    Boolean?
  homeScore    Int?
  awayScore    Int?
  createdAt    DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([fixtureId])
  @@index([fixtureId, type])
}

model FixtureLineup {
  id              String  @id @default(cuid())
  fixtureId       Int     @unique
  lineupStatus    String  @default("unavailable") // confirmed, predicted, unavailable
  homeFormation   String  @default("")
  awayFormation   String  @default("")
  homePlayers     String  @default("[]") // JSON array of player objects
  awayPlayers     String  @default("[]") // JSON array of player objects
  homeSubstitutes String  @default("[]")
  awaySubstitutes String  @default("[]")
  homeUnavailable String  @default("[]") // injured/suspended
  awayUnavailable String  @default("[]")
  homeConfidence  Float?
  awayConfidence  Float?
  updatedAt       DateTime?
  createdAt       DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model FixtureOdds {
  id              String  @id @default(cuid())
  fixtureId       Int     @unique
  homeWin         Float?
  draw            Float?
  awayWin         Float?
  over15Goals     Float?
  over25Goals     Float?
  over35Goals     Float?
  under15Goals    Float?
  under25Goals    Float?
  under35Goals    Float?
  bttsYes         Float?
  bttsNo          Float?
  observedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model FixtureMetadata {
  id            String  @id @default(cuid())
  fixtureId     Int     @unique
  funFacts      String  @default("[]") // JSON array of {type_id, sentence}
  aiPreview     String  @default("")
  aiGeneratedAt DateTime?
  createdAt     DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model PlayerMatchStat {
  id              String  @id @default(cuid())
  fixtureId       Int
  playerId        Int
  teamId          Int
  minutesPlayed   Int     @default(0)
  rating          Float?
  goals           Int     @default(0)
  goalAssist      Int     @default(0)
  expectedGoals   Float   @default(0)
  expectedAssists Float   @default(0)
  totalShots      Int     @default(0)
  shotsOnTarget   Int     @default(0)
  totalPass       Int     @default(0)
  accuratePass    Int     @default(0)
  keyPass         Int     @default(0)
  totalTackle     Int     @default(0)
  interception    Int     @default(0)
  yellowCard      Int     @default(0)
  redCard         Int     @default(0)
  saves           Float?
  createdAt       DateTime @default(now())

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id])

  @@index([fixtureId])
  @@index([playerId])
  @@index([teamId])
}

model Standing {
  id          String  @id @default(cuid())
  leagueId    Int
  seasonId    Int
  teamId      Int
  position    Int
  played      Int     @default(0)
  won         Int     @default(0)
  drawn       Int     @default(0)
  lost        Int     @default(0)
  gf          Int     @default(0)
  ga          Int     @default(0)
  gd          Int     @default(0)
  pts         Int     @default(0)
  xgf         Float?
  xga         Float?
  xgd         Float?
  xgGames     Int?
  form        String  @default("") // "WWLDW"
  isLive      Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([leagueId, seasonId, teamId])
  @@index([leagueId, seasonId])
  @@index([teamId])
}

// ============================================================================
// ENGINE — TEAM INTELLIGENCE
// ============================================================================

model TeamDNA {
  id                          String   @id @default(cuid())
  teamId                      Int      @unique

  // Home identity
  homeAttackStrength          Float    @default(1.0)  // Normalized 0.5-2.0
  homeDefenseStrength         Float    @default(1.0)
  homeAvgGoalsScored          Float    @default(0)
  homeAvgGoalsConceded        Float    @default(0)
  homeAvgXgScored             Float    @default(0)
  homeAvgXgConceded           Float    @default(0)
  homeAvgPossession           Float    @default(50)
  homeAvgShots                Float    @default(0)
  homeAvgShotsOnTarget        Float    @default(0)
  homeAvgCorners              Float    @default(0)
  homeWinPct                  Float    @default(0)
  homeDrawPct                 Float    @default(0)
  homeLossPct                 Float    @default(0)
  homeCleanSheetPct           Float    @default(0)
  homeBttsPct                 Float    @default(0)
  homeOver25Pct               Float    @default(0)

  // Away identity
  awayAttackStrength          Float    @default(1.0)
  awayDefenseStrength         Float    @default(1.0)
  awayAvgGoalsScored          Float    @default(0)
  awayAvgGoalsConceded        Float    @default(0)
  awayAvgXgScored             Float    @default(0)
  awayAvgXgConceded           Float    @default(0)
  awayAvgPossession           Float    @default(50)
  awayAvgShots                Float    @default(0)
  awayAvgShotsOnTarget        Float    @default(0)
  awayAvgCorners              Float    @default(0)
  awayWinPct                  Float    @default(0)
  awayDrawPct                 Float    @default(0)
  awayLossPct                 Float    @default(0)
  awayCleanSheetPct           Float    @default(0)
  awayBttsPct                 Float    @default(0)
  awayOver25Pct               Float    @default(0)

  // Style vectors (0-1 scale)
  possessionStyle             Float    @default(0.5)  // 1.0 = possession-dominant
  pressingIntensity           Float    @default(0.5)  // 1.0 = high press
  counterAttackPropensity     Float    @default(0.5)  // 1.0 = counter-heavy
  defensiveSolidity           Float    @default(0.5)  // 1.0 = fortress defense
  setPieceThreat              Float    @default(0.5)  // 1.0 = set piece specialists
  crossingPropensity          Float    @default(0.5)  // 1.0 = crossing team
  longBallPropensity          Float    @default(0.5)  // 1.0 = long ball team
  tempo                       Float    @default(0.5)  // 1.0 = high tempo
  lateGoalThreat              Float    @default(0.5)  // 1.0 = scores late often
  earlyGoalThreat             Float    @default(0.5)  // 1.0 = scores early often

  // Behavioral patterns
  rotationPct                 Float    @default(0)    // How much they rotate squad (0-1)
  homeAdvantageCoefficient    Float    @default(0.2)  // Per-team home advantage
  xgOverperformance           Float    @default(0)    // Goals vs xG ratio (1.0 = exact)
  xgUnderperformance          Float    @default(0)    // When they concede more than xGA
  formVolatility              Float    @default(0.5)  // 1.0 = very volatile form
  comebackPct                 Float    @default(0)    // How often they come from behind
  collapsePct                 Float    @default(0)    // How often they lose from winning

  // Sample sizes
  homeSampleSize              Int      @default(0)
  awaySampleSize              Int      @default(0)

  lastComputedAt              DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model TeamELO {
  id              String   @id @default(cuid())
  teamId          Int
  eloRating       Float    @default(1500)
  eloHomeRating   Float    @default(1500)
  eloAwayRating   Float    @default(1500)
  leagueId        Int?
  seasonId        Int?
  matchesPlayed   Int      @default(0)
  lastMatchDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])

  @@unique([teamId, leagueId, seasonId])
  @@index([teamId])
  @@index([eloRating])
}

model TeamForm {
  id           String   @id @default(cuid())
  teamId       Int
  fixtureId    Int
  opponentId   Int
  isHome       Boolean
  result       String   // W, D, L
  goalsFor     Int
  goalsAgainst Int
  xgFor        Float    @default(0)
  xgAgainst    Float    @default(0)
  possession   Float    @default(50)
  shots        Int      @default(0)
  shotsOnTarget Int     @default(0)
  opponentElo  Float    @default(1500)
  formScore    Float    @default(0.5)  // Weighted 0-1
  momentum     Float    @default(0)    // Trending direction
  eventDate    DateTime
  createdAt    DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId, eventDate])
  @@index([teamId])
}

// ============================================================================
// ENGINE — PREDICTIONS & LEARNING
// ============================================================================

model Prediction {
  id                String   @id @default(cuid())
  fixtureId         Int      @unique

  // Match result probabilities
  probHomeWin       Float    @default(0)
  probDraw          Float    @default(0)
  probAwayWin       Float    @default(0)
  predictedResult   String   @default("") // H, D, A

  // Expected goals
  expectedHomeGoals Float    @default(0)
  expectedAwayGoals Float    @default(0)

  // Over/Under
  probOver15        Float    @default(0)
  probOver25        Float    @default(0)
  probOver35        Float    @default(0)

  // BTTS
  probBttsYes       Float    @default(0)

  // Most likely score
  mostLikelyScore   String   @default("")

  // Confidence & model info
  confidence        Float    @default(0)   // 0-1
  modelVersion      String   @default("v1.0")

  // Context analysis
  homeAdvantageAdj  Float    @default(0)   // Calculated home advantage for this specific match
  formAdvantage     Float    @default(0)   // Which team has form advantage (-1 to 1)
  restAdvantage     Float    @default(0)   // Which team has more rest (-1 to 1)
  motivationScore   Float    @default(0.5) // How motivated are both teams (0-1)
  derbyFactor       Float    @default(0)   // Derby intensity modifier
  rotationRisk      Float    @default(0)   // Risk of squad rotation

  // Value analysis
  valueDetected     Boolean  @default(false)
  valueEdge         Float    @default(0)   // Edge vs market odds
  kellyStake        Float    @default(0)   // Suggested Kelly stake fraction
  recommendedBet    String   @default("")  // Best value bet

  // Ensemble breakdown (JSON)
  ensembleDetail    String   @default("{}") // Per-model breakdown

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  outcome PredictionOutcome?
}

model PredictionOutcome {
  id                String   @id @default(cuid())
  predictionId      String   @unique
  fixtureId         Int      @unique

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  // Actual result
  actualHomeScore   Int      @default(0)
  actualAwayScore   Int      @default(0)
  actualResult      String   @default("") // H, D, A
  actualOver25      Boolean  @default(false)
  actualBtts        Boolean  @default(false)

  // Accuracy tracking
  resultCorrect     Boolean?
  scoreExact        Boolean?
  homeGoalsError    Float?
  awayGoalsError    Float?
  probCalibrationError Float?

  // Market tracking
  bestMarketOdds    String   @default("{}")  // JSON of best odds at prediction time
  valueBetWon       Boolean?

  createdAt         DateTime @default(now())

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@index([fixtureId])
}

model ModelWeights {
  id                    String   @id @default(cuid())
  modelVersion          String   @default("v1.0")

  // Ensemble weights
  poissonWeight         Float    @default(0.35)
  eloWeight             Float    @default(0.25)
  formWeight            Float    @default(0.20)
  styleMatchupWeight    Float    @default(0.10)
  contextWeight         Float    @default(0.10)

  // Feature adjustments (learned over time)
  homeAdvantageBase     Float    @default(0.2)
  dixonColesRho         Float    @default(-0.13) // Low-scoring correction
  formDecayRate         Float    @default(0.85)  // Exponential decay per match
  eloKFactor            Float    @default(32)    // ELO sensitivity
  confidenceThreshold   Float    @default(0.6)   // Min confidence to recommend
  valueEdgeThreshold    Float    @default(0.05)  // Min edge to flag value

  // Performance tracking
  totalPredictions      Int      @default(0)
  correctResults        Int      @default(0)
  resultAccuracy        Float    @default(0)
  avgCalibrationError   Float    @default(0)
  valueBetProfit        Float    @default(0)

  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isActive])
}

// ============================================================================
// SAAS — AUTH & USERS
// ============================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  image         String?
  plan          String   @default("free") // free, pro, elite
  stripeCustomerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
